# ============================================
# GSDMS - .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Production builds
dist/
build/
.next/
out/

# Environment variables (CRITICAL: never commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Database
*.db
*.sqlite
*.sqlite3

# Uploads (user-generated content)
uploads/
backend/uploads/

# Prisma
backend/prisma/migrations/

# Logs
logs/
# لكن لا تتجاهل وحدة الكود المسمّاة logs
!backend/src/modules/logs/
!backend/src/modules/logs/**
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS files
desktop.ini
.Spotlight-V100
.Trashes

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.eslintcache
.npm
.next/cache

# Misc
*.tar.gz
*.zip
!gsdms-update/*.zip
