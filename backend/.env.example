# ===========================================
# GSDMS Backend - Environment Variables
# انسخ هذا الملف باسم .env وعدّل القيم
# ===========================================

# Application
NODE_ENV=development
PORT=3100
APP_NAME=GSDMS
APP_URL=http://localhost:3100

# Database (MySQL via XAMPP)
DATABASE_URL="mysql://root:@localhost:3306/gsdms"

# JWT Authentication
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Redis (optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (optional - for file storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gsdms-files

# Elasticsearch (optional - for full-text search)
ELASTICSEARCH_NODE=http://localhost:9200

# AI (OCR + استخراج موضوع المعاملة من المستند الوارد)
# يتطلب اتصالاً بالإنترنت من الخادم. اتركه فارغاً لتعطيل ميزة الاستخراج التلقائي.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# البريد (SMTP) - لإرسال رمز التحقّق (OTP) عند اعتماد المعاملات.
# اتركه فارغاً في التطوير ليُسجَّل الرمز في سجلّ الخادم بدل إرساله.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=نظام الأرشفة <no-reply@gsdms.local>

# Logging
LOG_LEVEL=debug
